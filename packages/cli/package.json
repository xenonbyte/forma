{
  "name": "@xenonbyte/forma-cli",
  "version": "0.1.6",
  "description": "User-facing Forma CLI for local design workspace, MCP startup, web serving, and agent installation.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "bin",
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xenonbyte/forma.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/xenonbyte/forma#readme",
  "bugs": {
    "url": "https://github.com/xenonbyte/forma/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "forma": "./bin/forma.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsx ../../scripts/copy-assets.ts",
    "prepack": "pnpm --dir ../.. build",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@xenonbyte/forma-core": "workspace:*",
    "@xenonbyte/forma-mcp": "workspace:*",
    "@xenonbyte/forma-server": "workspace:*"
  }
}
