{
  "name": "@xenonbyte/forma-core",
  "version": "0.1.8",
  "description": "Core services and persistence for the Forma local design workspace.",
  "license": "UNLICENSED",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./quality": {
      "types": "./dist/quality/index.d.ts",
      "import": "./dist/quality/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xenonbyte/forma.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/xenonbyte/forma#readme",
  "bugs": {
    "url": "https://github.com/xenonbyte/forma/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && node ../../scripts/copy-core-assets.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@vzi-core/format": "workspace:*",
    "@vzi-core/parser": "workspace:*",
    "@vzi-core/transformer": "workspace:*",
    "@vzi-core/types": "workspace:*",
    "js-yaml": "^4.1.0",
    "node-html-parser": "^7.1.0",
    "puppeteer": "^25.1.0",
    "sharp": "^0.34.5",
    "zod": "^4.1.0"
  }
}
